      "content" : [
        {
          "anchor" : "discussion",
          "level" : 2,
          "text" : "Discussion",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "The encoder applies dot-stuffing per RFC 5321 §4.5.2 and adds a trailing ",
              "type" : "text"
            },
            {
              "code" : "<CRLF>",
              "type" : "codeVoice"
            },
            {
              "text" : " to the payload before the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "<CRLF>.<CRLF>",
              "type" : "codeVoice"
            },
            {
              "text" : " terminator if the payload does not already end with one.",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "Bare LFs in the payload pass through unchanged — strict servers may reject such payloads.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "No maximum message size is enforced. Developers are responsible for keeping the message within reasonable sizes.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
