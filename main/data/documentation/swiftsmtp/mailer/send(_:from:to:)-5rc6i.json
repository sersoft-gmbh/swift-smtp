    },
    {
      "kind" : "parameters",
      "parameters" : [
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The full RFC 2822 message bytes (headers, blank line, body). Caller is responsible for content; this method does not validate or transform the headers.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "messageData"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The envelope sender (used for ",
                  "type" : "text"
                },
                {
                  "code" : "MAIL FROM",
                  "type" : "codeVoice"
                },
                {
                  "text" : "). Must not contain CR or LF.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "from"
        },
        {
          "content" : [
            {
              "inlineContent" : [
                {
                  "text" : "The envelope recipients (used for ",
                  "type" : "text"
                },
                {
                  "code" : "RCPT TO",
                  "type" : "codeVoice"
                },
                {
                  "text" : "). Must be non-empty and must not contain CR or LF.",
                  "type" : "text"
                }
              ],
              "type" : "paragraph"
            }
          ],
          "name" : "to"
        }
      ]
    },
    {
      "content" : [
        {
          "anchor" : "return-value",
          "level" : 2,
          "text" : "Return Value",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "A future that will complete with the result of sending the message. Fails immediately with ",
              "type" : "text"
            },
            {
              "code" : "MissingRecipientsError",
              "type" : "codeVoice"
            },
            {
              "text" : " if ",
              "type" : "text"
            },
            {
              "code" : "to",
              "type" : "codeVoice"
            },
            {
              "text" : " is empty, or ",
              "type" : "text"
            },
            {
              "code" : "InvalidEnvelopeAddressError",
              "type" : "codeVoice"
            },
            {
              "text" : " if any envelope address contains CR or LF.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    },
    {
      "content" : [
        {
          "anchor" : "discussion",
          "level" : 2,
          "text" : "Discussion",
          "type" : "heading"
        },
        {
          "inlineContent" : [
            {
              "text" : "Use this overload when the caller already owns the canonical RFC 2822 bytes for the message, e.g. when the same bytes",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "must be delivered to SMTP ",
              "type" : "text"
            },
            {
              "code" : "DATA",
              "type" : "codeVoice"
            },
            {
              "text" : " and stored verbatim via IMAP ",
              "type" : "text"
            },
            {
              "code" : "APPEND",
              "type" : "codeVoice"
            },
            {
              "text" : ", when the message has been DKIM-signed and",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "must not be re-serialised, or when forwarding a message retrieved from another mail store.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The SMTP envelope (",
              "type" : "text"
            },
            {
              "code" : "from",
              "type" : "codeVoice"
            },
            {
              "text" : " \/ ",
              "type" : "text"
            },
            {
              "code" : "to",
              "type" : "codeVoice"
            },
            {
              "text" : ") is independent of the RFC 2822 ",
              "type" : "text"
            },
            {
              "code" : "From:",
              "type" : "codeVoice"
            },
            {
              "text" : " \/ ",
              "type" : "text"
            },
            {
              "code" : "To:",
              "type" : "codeVoice"
            },
            {
              "text" : " headers. Pass the actual SMTP envelope",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "here — typically including any BCC recipients that do not appear in the headers.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The encoder applies dot-stuffing per RFC 5321 §4.5.2 and adds a trailing ",
              "type" : "text"
            },
            {
              "code" : "<CRLF>",
              "type" : "codeVoice"
            },
            {
              "text" : " to the payload before the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "code" : "<CRLF>.<CRLF>",
              "type" : "codeVoice"
            },
            {
              "text" : " terminator if the payload does not already end with one. Bare LFs in the payload pass through",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "unchanged — strict servers may reject such payloads.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "The envelope addresses must not contain a carriage return or line feed; either would let arbitrary SMTP",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "commands be injected into the session. Such addresses are rejected up front with ",
              "type" : "text"
            },
            {
              "code" : "InvalidEnvelopeAddressError",
              "type" : "codeVoice"
            },
            {
              "text" : ".",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        },
        {
          "inlineContent" : [
            {
              "text" : "No maximum message size is enforced. The entire payload is buffered in memory while it is encoded, so the",
              "type" : "text"
            },
            {
              "text" : " ",
              "type" : "text"
            },
            {
              "text" : "caller is responsible for keeping the message within a size their environment and server can handle.",
              "type" : "text"
            }
          ],
          "type" : "paragraph"
        }
      ],
      "kind" : "content"
    }
  ],
