    {
      "text" : "Represents an email whose message is pre-composed (e.g. a pre-built RFC 2822 payload).",
      "type" : "text"
    },
    {
      "text" : " ",
      "type" : "text"
    },
    {
      "text" : "Use this type when the canonical RFC 2822 bytes for the message already exist, e.g. when the same bytes",
